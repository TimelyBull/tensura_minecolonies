<window size="400 244" lightbox="true"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/main/src/main/resources/assets/blockui/gui/block_ui.xsd">

    <!-- Native MC content panel (same paper texture the race picker uses). -->
    <image source="minecolonies:textures/gui/builderhut/builder_paper_wide2.png" size="400 244"/>

    <!-- Title + a current-magicule counter, nudged down for more top spacing. -->
    <text id="title" size="400 11" pos="0 14" textalign="MIDDLE" color="black"
          label="§lCitizen Roster§r"/>
    <text id="magCount" size="400 10" pos="0 27" textalign="MIDDLE" color="black"/>

    <!-- Name search. -->
    <text size="60 11" pos="64 42" textalign="RIGHT" color="black" label="Search:"/>
    <input id="search" size="170 12" pos="130 41" color="black" maxlength="64"/>

    <!-- Roster list. One row template (the single child <view>); the window's
         DataProvider fills name/EP/status and the per-row buttons per element. -->
    <list id="roster" size="360 152" pos="20 56">
        <view size="100% 22">
            <!-- Selection indicator: a plain (non-clickable) image; the window
                 swaps it between the plain / checked mini button (native MC
                 checkbox pair) and owns all selection via click + drag paint. -->
            <image id="sel" size="14 15" pos="4 3"
                   source="minecolonies:textures/gui/builderhut/builder_button_mini.png"/>

            <text id="name"   size="150 11" pos="24 2"  color="black"/>
            <text id="ep"     size="120 9"  pos="24 12" color="black" textscale="0.8"/>
            <text id="status" size="86 11"  pos="172 6" textalign="RIGHT" color="black"/>

            <!-- Per-row immediate action: "Summon" (in colony) / "Send" (at side). -->
            <button id="act" size="58 16" pos="264 3" color="black"
                    source="minecolonies:textures/gui/builderhut/builder_button_quite_small.png"
                    label="Summon"/>
        </view>
    </list>

    <!-- Footer: bulk action + clear, shown only when >= 2 are selected. -->
    <text id="selCount" size="360 11" pos="20 209" textalign="MIDDLE" color="black"/>
    <button id="bulk" size="210 18" pos="30 222" color="black"
            source="minecolonies:textures/gui/builderhut/builder_button_large.png"
            label="Summon Selected"/>
    <button id="clear" size="60 18" pos="250 222" color="black"
            source="minecolonies:textures/gui/builderhut/builder_button_quite_small.png"
            label="Clear"/>

</window>
