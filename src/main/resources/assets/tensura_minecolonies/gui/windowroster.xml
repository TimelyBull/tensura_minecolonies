<window size="400 260" lightbox="true"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/main/src/main/resources/assets/blockui/gui/block_ui.xsd">

    <!-- Flat cream paper panel (MC's paper texture — matches the mockup look).
         All custom colours are set in Java (BlockUI's XML color attr only handles
         named colours reliably); borders use <box> panes recoloured at runtime. -->
    <image source="minecolonies:textures/gui/builderhut/builder_paper_wide2.png" size="400 260"/>

    <!-- ===================== HEADER ===================== -->
    <text id="title" size="260 16" pos="16 12" color="black" textscale="1.3" label="§lCitizen Roster§r"/>
    <text id="colonyName" size="106 10" pos="16 32" color="black" label="[colony name]"/>
    <!-- Reputation tier + value of the header colony; coloured per tier in
         Java. Wide + slightly downscaled so the longest descriptor
         ("Passive-Aggressive · NN") fits without truncation. -->
    <text id="repLine" size="126 10" pos="124 32" textalign="MIDDLE_RIGHT" textscale="0.85" color="black" label=""/>
    <box id="divider" size="368 1" pos="16 48" color="black"/>

    <!-- Diplomacy tab — opens the faction Diplomacy screen (Stage 1).
         Sits in the header between the title and the slime/badge. -->
    <button id="diplomacy" size="64 16" pos="186 13" color="black"
            source="tensura_minecolonies:textures/gui/roster/btn_tan.png"
            label="Diplomacy"/>

    <!-- Slime peeking over the top edge, next to the magicule badge.
         Source is 640x512 (1.25:1) — keep that ratio so it isn't squished. -->
    <image id="slime" source="tensura_minecolonies:textures/gui/roster/slime.png" size="36 29" pos="256 -3"/>

    <!-- Magicule badge: bordered box + purple diamond + count.
         Nudged down so it sits vertically centred against the title/subtitle. -->
    <box id="magBadge" size="92 26" pos="296 14" color="black"/>
    <image source="tensura_minecolonies:textures/gui/roster/diamond.png" size="14 14" pos="304 20"/>
    <text id="magCount" size="64 12" pos="322 21" color="black" label="0"/>

    <!-- ===================== SEARCH ===================== -->
    <!-- Hint is BEHIND the input so the input covers the whole bar: clicking
         anywhere in the box focuses the field. Input text colour is set to the
         hint colour in Java. -->
    <box id="searchBox" size="368 18" pos="16 54" color="black"/>
    <text id="searchHint" size="200 10" pos="24 58" color="black" label="Search citizens…"/>
    <input id="search" size="362 15" pos="18 55" color="black" maxlength="64"/>

    <!-- ===================== LIST ===================== -->
    <!-- One compressed row card (24px pitch). DataProvider fills each element. -->
    <list id="roster" size="376 144" pos="12 76">
        <view size="100% 24">
            <box id="card" size="100% 21" pos="0 0" color="black"/>

            <!-- Selection indicator: a plain (non-clickable) image; the window
                 swaps it plain/checked and owns all selection via click + drag. -->
            <image id="sel" size="13 13" pos="7 4"
                   source="minecolonies:textures/gui/builderhut/builder_button_mini.png"/>

            <!-- Row text: same scale + baseline so the columns line up. -->
            <text id="name" size="96 11" pos="26 6"  color="black"/>
            <text id="ep"   size="68 11" pos="126 6" color="black"/>

            <!-- Status pill: bg image (green/blue, swapped per row) + label. -->
            <image id="pillBg" size="92 15" pos="196 3"
                   source="tensura_minecolonies:textures/gui/roster/pill_green.png"/>
            <text  id="pillText" size="92 11" pos="196 6" textalign="MIDDLE" color="black" label="In colony"/>

            <!-- Action: source swapped green(Summon)/tan(Send), label set per row. -->
            <button id="act" size="60 16" pos="296 3" color="black"
                    source="tensura_minecolonies:textures/gui/roster/btn_green.png"
                    label="Summon"/>
        </view>
    </list>

    <!-- ===================== FOOTER ===================== -->
    <!-- Bulk group bar (shown only when >= 2 are selected). -->
    <button id="groupSummon" size="116 16" pos="12 224" color="black"
            source="tensura_minecolonies:textures/gui/roster/btn_green.png"
            label="Group Summon"/>
    <button id="groupSend" size="116 16" pos="132 224" color="black"
            source="tensura_minecolonies:textures/gui/roster/btn_tan.png"
            label="Group Send"/>
    <button id="clear" size="56 16" pos="252 224" color="black"
            source="minecolonies:textures/gui/builderhut/builder_button_quite_small.png"
            label="Clear"/>

    <!-- Counts (hidden while the bulk bar is showing). Moved up off the edge. -->
    <text id="countCitizens" size="180 10" pos="16 226" color="black" label="0 citizens"/>
    <text id="countAtSide" size="180 10" pos="204 226" textalign="MIDDLE_RIGHT" color="black" label="0 at your side"/>

</window>
